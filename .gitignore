# Packaged release artefacts produced by `flutter build windows --release`
# + the staging step in dist/. Regeneratable; never commit binaries.
dist/

# Throwaway preview output from `tools/extract_logo_no_bg.dart` and any
# future tooling-side debug renders. The script writes a dark-glass
# composite of the in-app logo here so an operator can sanity-check
# the alpha-keying before committing the asset; not a shipped file.
tools/_out/

# Secrets and local environment
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12

# Local Remote Access bearer token, written by tool/remote_pair.dart
# during dev smoke. Treat as a secret — anyone with this token can
# drive the desktop chat over the LAN/Tailscale bind.
tool/.lumen_remote_token
*.pfx
credentials.json
secrets.json

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

